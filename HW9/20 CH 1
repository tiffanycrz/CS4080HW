// table.c

// CHANGE
// Simple hash function for all Value types

static uint32_t hashValue(Value key) {
  switch (key.type) {

    case VAL_BOOL:
      return AS_BOOL(key) ? 1 : 2;

    case VAL_NIL:
      return 3;

    case VAL_NUMBER:
      return (uint32_t)AS_NUMBER(key);

    case VAL_OBJ:
      // strings already have hash
      return AS_STRING(key)->hash;

    default:
      return 0;
  }
}

// CHANGE 
// findEntry uses Value instead of ObjString*

static Entry* findEntry(Entry* entries, int capacity, Value key) {

  uint32_t index = hashValue(key) & (capacity - 1);

  Entry* tombstone = NULL;

  for (;;) {

    Entry* entry = &entries[index];

    if (IS_NIL(entry->key)) {

      if (IS_NIL(entry->value)) {
        return tombstone ? tombstone : entry;
      } else {
        if (!tombstone) tombstone = entry;
      }

    } else if (valuesEqual(entry->key, key)) {
      return entry;
    }

    index = (index + 1) & (capacity - 1);
  }
}
