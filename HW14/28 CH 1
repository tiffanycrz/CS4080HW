// object.h

typedef struct {
  Obj obj;
  ObjString* name;

  Table methods;

  // Cached pointer to init() method.
  // NULL if class has no initializer.
  ObjClosure* initializer;

} ObjClass;

// object.c

ObjClass* newClass(ObjString* name) {
  ObjClass* klass = ALLOCATE_OBJ(ObjClass, OBJ_CLASS);

  klass->name = name;

  initTable(&klass->methods);

  // No initializer initially
  klass->initializer = NULL;

  return klass;
}

// vm.c

static void defineMethod(ObjString* name) {
  Value method = peek(0);

  ObjClass* klass = AS_CLASS(peek(1));

  tableSet(&klass->methods, name, method);

  // Cache init() directly on class
  if (name == vm.initString) {
    klass->initializer = AS_CLOSURE(method);
  }

  pop();
}

case OBJ_CLASS: {
  ObjClass* klass = AS_CLASS(callee);

  vm.stackTop[-argCount - 1] =
      OBJ_VAL(newInstance(klass));

  // CHANGED:
  if (klass->initializer != NULL) {
    return call(klass->initializer,
                argCount);
  }

  if (argCount != 0) {
    runtimeError(
        "Expected 0 arguments but got %d.",
        argCount);
    return false;
  }

  return true;
}

// OP_INHERIT copies methods table
// Need to also inherit cached initializer

case OP_INHERIT: {
  Value superclass = peek(1);

  if (!IS_CLASS(superclass)) {
    runtimeError("Superclass must be a class.");
    return INTERPRET_RUNTIME_ERROR;
  }

  ObjClass* subclass = AS_CLASS(peek(0));
  ObjClass* superklass = AS_CLASS(superclass);

  tableAddAll(&superklass->methods,
              &subclass->methods);

  // Copy cached initializer too
  subclass->initializer =
      superklass->initializer;

  pop();
  break;
}
