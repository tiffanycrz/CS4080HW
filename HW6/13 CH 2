// LoxClass
package com.craftinginterpreters.lox;

import java.util.List;
import java.util.Map;

class LoxClass implements LoxCallable {
  final String name;
  final LoxClass superclass;
  private final Map<String, LoxFunction> methods;

  LoxClass(String name, LoxClass superclass,
           Map<String, LoxFunction> methods) {
    this.name = name;
    this.superclass = superclass;
    this.methods = methods;
  }

  // Method lookup for BETA: prefer top of hierarchy

  LoxFunction findMethod(String name) {
    // Check superclass first
    if (superclass != null) {
      LoxFunction superMethod = superclass.findMethod(name);
      if (superMethod != null) return superMethod;
    }

    // Then check this class
    return methods.get(name); // returns null if not found
  }

  @Override
  public Object call(Interpreter interpreter, List<Object> arguments) {
    LoxInstance instance = new LoxInstance(this);

    LoxFunction initializer = findMethod("init");
    if (initializer != null) {
      initializer.bind(instance).call(interpreter, arguments);
    }

    return instance;
  }

  @Override
  public int arity() {
    LoxFunction initializer = findMethod("init");
    if (initializer == null) return 0;
    return initializer.arity();
  }

  @Override
  public String toString() {
    return name;
  }
}

// Expr
package com.craftinginterpreters.lox;

import java.util.List;

abstract class Expr {
  interface Visitor<R> {
    R visitVariableExpr(Variable expr);
    R visitAssignExpr(Assign expr);
    R visitInnerExpr(Inner expr);  // New visitor for 'inner'
    // ...
  }

  static class Inner extends Expr {
    final Token keyword; // the 'inner' token
    Inner(Token keyword) { this.keyword = keyword; }
    @Override
    <R> R accept(Visitor<R> visitor) { return visitor.visitInnerExpr(this); }
  }

  abstract <R> R accept(Visitor<R> visitor);
}

// Parser
private Expr primary() {
  // ...

  if (match(INNER)) {
    Token keyword = previous();
    return new Expr.Inner(keyword);
  }

  // ...
}

// Resolver
@Override
public Void visitInnerExpr(Expr.Inner expr) {
  // Inner is only valid inside a method of a class
  if (currentClass == ClassType.NONE) {
    Lox.error(expr.keyword, "Can't use 'inner' outside of a class.");
  }

  resolveLocal(expr, expr.keyword);
  return null;
}

// Interpreter
@Override
public Object visitInnerExpr(Expr.Inner expr) {
  // 'inner' must be called inside a method; this.class is current instance class
  LoxFunction method = ((LoxInstance) env.getThis()).klass.innerMethod(expr.keyword);
  if (method == null) return null; // do nothing if no subclass method
  return method.bind(env.getThis()).call(this, Collections.emptyList());
}

// LoxClass helper
LoxFunction innerMethod(Token name) {
  // Find nearest subclass's method (below this class in hierarchy)
  if (subclasses != null) {
    for (LoxClass subclass : subclasses) {
      if (subclass.methods.containsKey(name.lexeme)) {
        return subclass.methods.get(name.lexeme);
      }
    }
  }
  return null;
}
