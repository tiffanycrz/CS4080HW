// Interpreter.java:

@Override
public Object visitIncrementExpr(Expr.Increment expr) {
  if (!(expr.variable instanceof Expr.Variable)) {
    throw new RuntimeError(expr.operator,
        "Operand must be a variable.");
  }

  String name = ((Expr.Variable)expr.variable).name.lexeme;

  Object value = environment.get(((Expr.Variable)expr.variable).name);

  if (!(value instanceof Double)) {
    throw new RuntimeError(expr.operator,
        "Operand must be a number.");
  }

  double newValue = (double)value + 1;
  environment.assign(((Expr.Variable)expr.variable).name, newValue);

  return newValue;
}
