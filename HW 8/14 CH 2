// chunk.h changes
typedef enum {
  OP_CONSTANT,

  // ADDED
  OP_CONSTANT_LONG,

  OP_NIL,
  OP_TRUE,
  OP_FALSE,
  ...
} OpCode;

// ADDED
// writes constant using OP_CONSTANT or OP_CONSTANT_LONG
void writeConstant(Chunk* chunk, Value value, int line);

// chunk.c changes
// ADDED FUNCTION
void writeConstant(Chunk* chunk, Value value, int line) {
  // add constant to constant table
  int constantIndex = addConstant(chunk, value);

  // if index fits in one byte, use normal instruction
  if (constantIndex <= 256) {
    writeChunk(chunk, OP_CONSTANT, line);
    writeChunk(chunk, (uint8_t)constantIndex, line);
  } else {
    // otherwise use OP_CONSTANT_LONG
    writeChunk(chunk, OP_CONSTANT_LONG, line);

    // write operand as 3 bytes
    writeChunk(chunk,
        (constantIndex >> 16) & 0xFF,
        line);

    writeChunk(chunk,
        (constantIndex >> 8) & 0xFF,
        line);

    writeChunk(chunk,
        constantIndex & 0xFF,
        line);
  }
}

