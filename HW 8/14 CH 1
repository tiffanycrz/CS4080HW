typedef struct {
  int count;
  int capacity;
  uint8_t* code;

  // CHANGED
  // Instead of storing one line per instruction, store runs of lines using run-length encoding.

  int* lines;        // stores line number
  int* lineCounts;   // stores how many instructions belong to that line

  int lineCount;     // number of RLE entries
  int lineCapacity;  // capacity for RLE arrays

  ValueArray constants;
} Chunk;

void initChunk(Chunk* chunk);
void freeChunk(Chunk* chunk);

void writeChunk(Chunk* chunk, uint8_t byte, int line);

