// chunck.c
#include <stdlib.h>

#include "chunk.h"
#include "memory.h"
#include "vm.h"

void initChunk(Chunk* chunk) {
  chunk->count = 0;
  chunk->capacity = 0;
  chunk->code = NULL;

  // CHANGED
  // initialize RLE line storage
  chunk->lines = NULL;
  chunk->lineCounts = NULL;
  chunk->lineCount = 0;
  chunk->lineCapacity = 0;

  initValueArray(&chunk->constants);
}

void freeChunk(Chunk* chunk) {
  FREE_ARRAY(uint8_t, chunk->code, chunk->capacity);

  // CHANGED
  // free RLE arrays instead of single lines array
  FREE_ARRAY(int, chunk->lines, chunk->lineCapacity);
  FREE_ARRAY(int, chunk->lineCounts, chunk->lineCapacity);

  freeValueArray(&chunk->constants);

  initChunk(chunk);
}

void writeChunk(Chunk* chunk, uint8_t byte, int line) {

  // grow bytecode array if needed
  if (chunk->capacity < chunk->count + 1) {

    int oldCapacity = chunk->capacity;
    chunk->capacity = GROW_CAPACITY(oldCapacity);

    chunk->code = GROW_ARRAY(
        uint8_t,
        chunk->code,
        oldCapacity,
        chunk->capacity
    );
  }

  chunk->code[chunk->count] = byte;
  chunk->count++;

  // CHANGED
  // Run-length encoding logic for line numbers
  // if this is the first line entry OR the line changed
  if (chunk->lineCount == 0 ||
      chunk->lines[chunk->lineCount - 1] != line) {

    // grow RLE arrays if needed
    if (chunk->lineCapacity < chunk->lineCount + 1) {

      int oldCapacity = chunk->lineCapacity;
      chunk->lineCapacity = GROW_CAPACITY(oldCapacity);

      chunk->lines = GROW_ARRAY(
          int,
          chunk->lines,
          oldCapacity,
          chunk->lineCapacity
      );

      chunk->lineCounts = GROW_ARRAY(
          int,
          chunk->lineCounts,
          oldCapacity,
          chunk->lineCapacity
      );
    }

    // create new run
    chunk->lines[chunk->lineCount] = line;
    chunk->lineCounts[chunk->lineCount] = 1;

    chunk->lineCount++;
  }
  else {
    // same line, increment run length
    chunk->lineCounts[chunk->lineCount - 1]++;
  }
}

int addConstant(Chunk* chunk, Value value) {

  push(value);

  writeValueArray(&chunk->constants, value);

  pop();

  return chunk->constants.count - 1;
}

// Returns the line number for a given instruction index
int getLine(Chunk* chunk, int instructionIndex) {

  int accumulated = 0;

  // iterate through RLE entries
  for (int i = 0; i < chunk->lineCount; i++) {

    accumulated += chunk->lineCounts[i];

    if (instructionIndex < accumulated) {
      return chunk->lines[i];
    }
  }

  return -1; // should never occur
}
